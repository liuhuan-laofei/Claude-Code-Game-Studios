{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Level Data",
  "type": "object",
  "properties": {
    "id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "waves": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "waiting_slots": {
      "type": "integer"
    }
  },
  "required": ["id", "name", "waves", "waiting_slots"],
  "additionalProperties": false
}
